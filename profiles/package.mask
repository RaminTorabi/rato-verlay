# Mask pre-release / beta versions that were tagged upstream but are
# not the latest stable release. Users can unmask individually if needed.
#
# To unmask: add the atom to /etc/portage/package.unmask/rato-verlay

# CloudWatch Agent 1.300067.0 — tagged upstream but not marked as
# latest stable release (latest stable is 1.300066.1 as of 2026-04-25)
=app-admin/amazon-cloudwatch-agent-1.300067.0

# Ramin Torabi <16882282+RaminTorabi@users.noreply.github.com> (2026-05-05)
# amazon-efs-utils-bin — prebuilt binary repackaging of AWS's
# official AL2023 RPM. Not yet validated end-to-end on a real Gentoo
# Update AMI build + live S3 Files mount. Unmask in the consumer's
# /etc/portage/package.unmask/ once you have validated install + run
# on the host.
net-fs/amazon-efs-utils-bin
